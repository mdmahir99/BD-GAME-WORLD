CREATE TABLE deposits (
id INT AUTO_INCREMENT PRIMARY KEY,
user_id INT,
amount INT,
status VARCHAR(20) DEFAULT 'pending'
);

CREATE TABLE withdraws (
id INT AUTO_INCREMENT PRIMARY KEY,
user_id INT,
amount INT,
status VARCHAR(20) DEFAULT 'pending'
);
CREATE TABLE users (
id INT AUTO_INCREMENT PRIMARY KEY,
username VARCHAR(50),
email VARCHAR(100),
password VARCHAR(255),
balance INT DEFAULT 0,
referral_code VARCHAR(50),
referred_by VARCHAR(50)
);

CREATE TABLE admin (
id INT AUTO_INCREMENT PRIMARY KEY,
username VARCHAR(50),
password VARCHAR(255)
);